---
interface Props {
  /**
   * Shadcn-style variant.
   * - default: neutral background
   * - primary: prominent (black/dark)
   * - secondary: muted gray
   * - outline: border, transparent bg
   * - ghost: no border, transparent, hover bg
   * - destructive: red/danger
   * - link: no border/bg, underline only
   */
  variant?: 'default' | 'primary' | 'secondary' | 'outline' | 'ghost' | 'destructive' | 'link';
  /** If set, render as <a href="..."> instead of <button> */
  href?: string;
  /** Button type when not a link */
  type?: 'button' | 'submit';
  /** Optional tooltip (title) */
  title?: string;
  /** Extra class names */
  class?: string;
}

const { variant = 'default', href, type = 'button', title, class: className = '' } = Astro.props;

const base =
  'inline-flex flex-shrink-0 cursor-pointer items-center justify-center gap-2 rounded-xl px-4 py-2 text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-400 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50';

const variantClasses: Record<NonNullable<Props['variant']>, string> = {
  default:
    'bg-gray-900 text-white hover:bg-gray-800',
  primary:
    'bg-black text-white hover:bg-gray-800',
  secondary:
    'border border-black-900 bg-black/10 text-gray-900 hover:bg-black/40',
  outline:
    'border border-black/30 bg-black/10 text-gray-900 hover:border-gray-400 hover:bg-black/30',
  ghost:
    'text-gray-900 hover:bg-black/10',
  destructive:
    'bg-red-600 text-white hover:bg-red-700',
  link:
    'underline decoration-gray-400 text-gray-900 hover:decoration-gray-600 hover:text-gray-700',
};

const classes = [base, variantClasses[variant], className].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes} title={title}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} title={title}>
    <slot />
  </button>
)}
