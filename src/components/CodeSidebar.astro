---
/**
 * Sticky sidebar with code/tech info (Core, Frameworks, Repos). Same data as old CodePopover.
 */
const GITHUB_USER = 'gideonchrapko';
const REPOS_TO_SHOW = 2;

function relativeTime(dateStr: string): string {
  const date = new Date(dateStr);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
  if (diffDays < 1) return 'Today';
  if (diffDays === 1) return '1d ago';
  if (diffDays < 7) return `${diffDays}d ago`;
  if (diffDays < 14) return '1w ago';
  if (diffDays < 30) return `${Math.floor(diffDays / 7)}w ago`;
  if (diffDays < 60) return '1mo ago';
  if (diffDays < 365) return `${Math.floor(diffDays / 30)}mo ago`;
  return `${Math.floor(diffDays / 365)}y ago`;
}

interface GhRepo {
  name: string;
  description: string | null;
  language: string | null;
  updated_at: string;
  html_url: string;
}

let publicRepos = 0;
let githubUrl = `https://github.com/${GITHUB_USER}`;
let repos: GhRepo[] = [];

const ghHeaders = { Accept: 'application/vnd.github.v3+json', 'User-Agent': 'portfolio-2026' };
try {
  const [userRes, reposRes] = await Promise.all([
    fetch(`https://api.github.com/users/${GITHUB_USER}`, { headers: ghHeaders }),
    fetch(`https://api.github.com/users/${GITHUB_USER}/repos?sort=updated&per_page=${REPOS_TO_SHOW}`, {
      headers: ghHeaders,
    }),
  ]);
  if (userRes.ok) {
    const user = await userRes.json();
    publicRepos = user.public_repos ?? 0;
    githubUrl = user.html_url ?? githubUrl;
  }
  if (reposRes.ok) {
    const list = await reposRes.json();
    repos = list.map(
      (r: {
        name: string;
        description: string | null;
        language: string | null;
        updated_at: string;
        html_url: string;
      }) => ({
        name: r.name,
        description: r.description,
        language: r.language,
        updated_at: r.updated_at,
        html_url: r.html_url,
      }),
    );
  }
} catch {
  publicRepos = 0;
  githubUrl = `https://github.com/${GITHUB_USER}`;
}
---

<aside class="code-sidebar w-full shrink-0 lg:sticky lg:top-24 lg:w-72 lg:self-start" aria-label="Code & tech">
  <div class="rounded-lg border border-gray-700 bg-[#0d0d0d] p-4 shadow-xl">
    <div
      class="space-y-2.5 text-left text-sm text-gray-300 [&_a]:underline [&_a]:decoration-gray-500 [&_a]:hover:decoration-gray-400 [&_a]:hover:text-gray-100"
    >
      <p class="text-xs text-gray-400">Selected repos &amp; active projects.</p>
      <div>
        <p class="mb-1 text-xs font-medium uppercase tracking-wider text-gray-500">— Core</p>
        <p class="ml-2 text-gray-300">TypeScript · JavaScript · HTML</p>
      </div>
      <div>
        <p class="mb-1 text-xs font-medium uppercase tracking-wider text-gray-500">— Frameworks</p>
        <p class="ml-2 text-gray-300">React · Next.js · Tailwind CSS · Astro</p>
      </div>
      <p class="border-t border-gray-700 pt-2 text-xs text-gray-400">
        <span>{publicRepos} public repos</span>
        {' · '}
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-100 underline decoration-gray-500 hover:decoration-gray-400">View GitHub →</a
        >
      </p>
      <div class="border-t border-gray-700 pt-2">
        <p class="mb-2 text-xs font-medium uppercase tracking-wider text-gray-500">— Achievements</p>
        <div class="flex gap-3">
          <div class="flex flex-1 flex-col items-center gap-1.5">
            <img
              src="https://github.githubassets.com/assets/pull-shark-default-498c279a747d.png"
              alt="Pull Shark"
              class="h-16 w-16"
              loading="lazy"
            />
            <span class="flex items-center gap-1 text-[9px] text-gray-500 leading-tight">
              Pull Shark
              <span
                class="inline-flex items-center rounded-full border border-gray-500 bg-gray-700 px-1.5 text-[8px] font-semibold leading-[14px] text-gray-300 shadow-sm"
                >x3</span
              >
            </span>
          </div>
          <div class="flex flex-1 flex-col items-center gap-1.5">
            <img
              src="https://github.githubassets.com/assets/quickdraw-default-39c6aec8ff89.png"
              alt="Quickdraw"
              class="h-16 w-16"
              loading="lazy"
            />
            <span class="text-[9px] text-gray-500 text-center leading-tight">Quickdraw</span>
          </div>
          <div class="flex flex-1 flex-col items-center gap-1.5">
            <img
              src="https://github.githubassets.com/assets/yolo-default-be0bbff04951.png"
              alt="YOLO"
              class="h-16 w-16"
              loading="lazy"
            />
            <span class="text-[9px] text-gray-500 text-center leading-tight">YOLO</span>
          </div>
        </div>
      </div>
      <div>
        <p class="mb-1 text-xs font-medium uppercase tracking-wider text-gray-500">— Repositories</p>
        <ul class="space-y-1.5 text-xs text-gray-300">
          {
            repos.length > 0 ? (
              repos.map((repo) => (
                <li>
                  <a
                    href={repo.html_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-medium text-gray-100 hover:underline"
                  >
                    [ {repo.name} ]
                  </a>
                  {repo.description && <p class="ml-2 text-gray-400">→ {repo.description}</p>}
                  <p class="ml-2 text-gray-500">
                    {repo.language ?? '—'} · Updated {relativeTime(repo.updated_at)}
                  </p>
                </li>
              ))
            ) : (
              <li class="text-gray-500">—</li>
            )
          }
        </ul>
      </div>
    </div>
  </div>
</aside>
