function color(count: number): string {
  if (count === 0) return 'bg-amber-100/15';
  if (count <= 3) return 'bg-amber-300';
  if (count <= 7) return 'bg-amber-400';
  if (count <= 15) return 'bg-amber-600';
  return 'bg-amber-800';
}
---

<div class="github-contribs">
  <div class="flex items-center justify-between">
    <h2 class="text-xs font-medium uppercase tracking-wider text-gray-500">Contributions</h2>
    <a
      href={`https://github.com/${GITHUB_USER}`}
      target="_blank"
      rel="noopener noreferrer"
      class="group inline-flex items-center gap-1 text-xs text-gray-500 no-underline hover:text-gray-800"
    >
      <span class="underline decoration-gray-400 group-hover:decoration-gray-600">GitHub</span>
      <span class="inline-block text-xs no-underline transition-transform duration-200 -rotate-45 group-hover:rotate-0"
        >→</span
      >
    </a>
  </div>

  <div class="mt-3 overflow-x-auto pb-1" style="overflow-y: hidden;">
    {
      years.map((y) => (
        <div class="flex gap-1.5 mt-1 first:mt-0">
          <div class="flex flex-col gap-[2px] w-7 shrink-0">
            {DAY_LABELS.map((label) => (
              <span class="block h-[7px] text-[8px] leading-none text-gray-400">{label}</span>
            ))}
          </div>

          {/* grid */}
          <div class="flex gap-[2px]">
            {y.weeks.map((week) => (
              <div class="flex flex-col gap-[2px]">
                {week.map((count) => (
                  <div class={`h-[7px] w-[7px] rounded-[1px] ${color(count)}`} />
                ))}
              </div>
            ))}
          </div>

          {/* year label */}
          <div class="flex items-start pt-0 w-12 shrink-0">
            <span
              class:list={[
                'text-[10px] tabular-nums leading-none',
                y.peak ? 'font-medium text-amber-700' : 'text-gray-500',
              ]}
            >
              {y.year}
              {y.peak && <span class="text-amber-600"> ★</span>}
            </span>
          </div>
        </div>
      ))
    }
  </div>

  <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1">
    <span class="text-[11px] text-gray-500">
      {totalContribs} contributions across 7 years
      <span class="text-gray-400"> · peak <span class="font-medium">2024</span></span>
    </span>
    <span class="flex items-center gap-1 text-[10px] text-gray-400">
      <span>Less</span>
      <div class="flex gap-[1px]">
        <div class="h-[8px] w-[8px] rounded-[1px] bg-amber-100/15"></div>
        <div class="h-[8px] w-[8px] rounded-[1px] bg-amber-300"></div>
        <div class="h-[8px] w-[8px] rounded-[1px] bg-amber-400"></div>
        <div class="h-[8px] w-[8px] rounded-[1px] bg-amber-600"></div>
        <div class="h-[8px] w-[8px] rounded-[1px] bg-amber-800"></div>
      </div>
      <span>More</span>
    </span>
  </div>
</div>

<style>
  .github-contribs {
    container-type: inline-size;
  }
  .github-contribs ::-webkit-scrollbar {
    height: 3px;
  }
  .github-contribs ::-webkit-scrollbar-thumb {
    background: rgb(156 163 175 / 0.25);
