---
import { getCollection } from 'astro:content';
import navConfig from '../data/nav-routes.json';
import NavPill from './NavPill.astro';

type SimpleDropdownEntry = { label: string; href: string };
type TreeDropdownEntry = {
  prefix: string;
  label?: string;
  href?: string;
  connector?: boolean;
  suffix?: string;
  level?: 'root' | 'category' | 'project';
};
type DropdownEntry = SimpleDropdownEntry | TreeDropdownEntry;

type TreeNode = {
  label: string;
  href: string;
  symbol?: string;
  suffix?: string;
  children?: TreeNode[];
};

type DropdownConfig = DropdownEntry[] | { tree: TreeNode[] };

type NavItem = {
  id: string;
  pillLabel: string;
  pillSlugLabel?: string;
  pillHref: string;
  pillOuterBg: string;
  pillLabelBg: string;
  dropdown?: DropdownConfig;
};

const rawItems = navConfig.items as NavItem[];

// All non-draft projects, grouped by category → Projects pill dropdown (web development, motion, design, then api/projects)
const allProjects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0)
);

const categoryOrder = ['web-development', 'motion', 'graphic-design'] as const;
const categoryLabels: Record<(typeof categoryOrder)[number], string> = {
  'web-development': 'web development',
  motion: 'motion',
  'graphic-design': 'design',
};

const projectsByCategory = categoryOrder.map((cat) => ({
  label: categoryLabels[cat],
  href: `/projects?category=${cat}`,
  children: allProjects
    .filter((p) => (p.data.category ?? 'graphic-design') === cat)
    .map((p) => ({ label: p.data.title, href: `/projects/${p.id}` })),
}));

const items: NavItem[] = rawItems.map((item) => {
  if (item.id !== 'projects' || !item.dropdown || !('tree' in item.dropdown) || !Array.isArray(item.dropdown.tree)) {
    return item;
  }
  const tree = item.dropdown.tree as TreeNode[];
  const projectsRoot = tree[0];
  const otherRoots = tree.slice(1);
  const newTree: TreeNode[] = [
    { ...projectsRoot, label: projectsRoot.label, href: projectsRoot.href, symbol: projectsRoot.symbol, children: projectsByCategory },
    ...otherRoots,
  ];
  return { ...item, dropdown: { tree: newTree } };
});

function isTreeEntry(entry: DropdownEntry): entry is TreeDropdownEntry {
  return typeof entry === 'object' && 'prefix' in entry;
}

function buildTreeLines(roots: TreeNode[]): TreeDropdownEntry[] {
  const lines: TreeDropdownEntry[] = [];
  const defaultSymbol = '○';

  function addNode(
    node: TreeNode,
    indent: string,
    branch: string,
    sym: string,
    depth: number
  ): void {
    const level: TreeDropdownEntry['level'] = depth === 0 ? 'root' : depth === 1 ? 'category' : 'project';
    lines.push({
      prefix: `${indent}${branch} ${sym} `,
      label: node.label,
      href: node.href,
      suffix: node.suffix,
      level,
    });
    const children = node.children;
    if (children?.length) {
      const childIndent = indent + '│  ';
      for (let j = 0; j < children.length; j++) {
        const child = children[j];
        const isLastChild = j === children.length - 1;
        const childSym = child.symbol ?? defaultSymbol;
        const childBranch = isLastChild ? '└' : '├';
        addNode(child, childIndent, childBranch, childSym, depth + 1);
      }
    }
  }

  for (let i = 0; i < roots.length; i++) {
    const root = roots[i];
    const isFirstRoot = i === 0;
    const isLastRoot = i === roots.length - 1;
    const sym = root.symbol ?? defaultSymbol;
    const rootBranch = isFirstRoot ? '┌' : isLastRoot ? '└' : '├';
    addNode(root, '', rootBranch, sym, 0);
    if (!isLastRoot) lines.push({ prefix: '│  ', connector: true });
  }
  return lines;
}

function getDropdownEntries(dropdown: DropdownConfig): DropdownEntry[] {
  if (Array.isArray(dropdown)) return dropdown;
  if (dropdown && 'tree' in dropdown && Array.isArray(dropdown.tree)) {
    return buildTreeLines(dropdown.tree as TreeNode[]);
  }
  return [];
}
---

<div class="flex flex-row flex-nowrap items-center justify-center gap-3" role="navigation" aria-label="Section">
  {items.map((item) => {
    const entries = item.dropdown ? getDropdownEntries(item.dropdown) : [];
    const isTree = entries.length > 0 && isTreeEntry(entries[0]);
    return <NavPill item={item} entries={entries} isTree={isTree} />;
  })}
</div>
