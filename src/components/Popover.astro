---
/**
 * Shadcn-style Popover: click-to-open panel that supports structured content.
 * Uses Astro.slots.render('content') + set:html so content appears only in the panel
 * (avoids Astro slot content rendering on the page). A hidden slot consumer prevents
 * the content from also rendering as a sibling.
 */
interface Props {
  /** Preferred side of the trigger to show the panel */
  side?: 'top' | 'bottom' | 'left' | 'right';
  /** Alignment of the panel relative to the trigger */
  align?: 'start' | 'center' | 'end';
  /** Optional class on the root wrapper */
  class?: string;
}

const { side = 'bottom', align = 'center', class: className = '' } = Astro.props;
const hasContent = Astro.slots.has('content');
const contentSlotHtml = hasContent ? await Astro.slots.render('content') : null;

const sideClasses: Record<NonNullable<Props['side']>, string> = {
  top: 'bottom-full left-1/2 -translate-x-1/2 mb-2',
  bottom: 'top-full left-1/2 -translate-x-1/2 mt-2',
  left: 'right-full top-1/2 -translate-y-1/2 mr-2',
  right: 'left-full top-1/2 -translate-y-1/2 ml-2',
};
const alignClasses: Record<NonNullable<Props['align']>, string> = {
  start: 'left-0',
  center: 'left-1/2 -translate-x-1/2',
  end: 'right-0 left-auto',
};
---

<div class={`popover-root relative inline-flex ${className}`.trim()} data-popover>
  <div class="popover-trigger-wrapper inline-flex cursor-pointer" data-popover-trigger>
    <slot name="trigger" />
  </div>
  <!-- Consume content slot so it doesn't render on the page; we show it in the panel via set:html -->
  {
    hasContent && (
      <div class="sr-only absolute h-0 w-0 overflow-hidden opacity-0" aria-hidden="true">
        <slot name="content" />
      </div>
    )
  }
  {
    hasContent && contentSlotHtml != null && (
      <div
        class={`popover-content pointer-events-none absolute z-50 hidden min-w-[16rem] max-w-[22rem] rounded-lg border border-gray-200 bg-white p-4 shadow-lg ${sideClasses[side]} ${alignClasses[align]}`}
        role="dialog"
        aria-hidden="true"
        data-popover-panel
      >
        <div class="popover-inner text-left text-sm text-gray-700 [&_a]:underline [&_a]:decoration-gray-400 [&_a]:hover:decoration-gray-600">
          <Fragment set:html={contentSlotHtml} />
        </div>
      </div>
    )
  }
</div>

<script>
  (function () {
    document.querySelectorAll('.popover-root[data-popover]').forEach((root) => {
      const trigger = root.querySelector('[data-popover-trigger]');
      const panel = root.querySelector<HTMLElement>('[data-popover-panel]');
      if (!trigger || !panel) return;
      const panelEl = panel;

      function open() {
        panelEl.classList.remove('hidden');
        panelEl.classList.add('pointer-events-auto');
        panelEl.setAttribute('aria-hidden', 'false');
      }
      function close() {
        panelEl.classList.add('hidden');
        panelEl.classList.remove('pointer-events-auto');
        panelEl.setAttribute('aria-hidden', 'true');
      }
      function toggle() {
        const isOpen = !panelEl.classList.contains('hidden');
        if (isOpen) close();
        else open();
      }

      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        toggle();
      });

      document.addEventListener('click', (e) => {
        if (root.contains(e.target as Node)) return;
        close();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    });
  })();
</script>
