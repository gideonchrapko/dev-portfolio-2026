---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  /** Page title (e.g. "About", "Projects"). Defaults to site name. */
  title?: string;
  /** Short description for OG and Twitter cards. */
  description?: string;
  /** Share image path (e.g. /og.png) or absolute URL. Relative paths are made absolute using site. */
  image?: string;
}
const { title, description, image } = Astro.props;
const pageTitle = title ? `${title} | Gideon Chrapko` : 'Gideon Chrapko | Front End Developer';
const site = import.meta.env.SITE ?? 'https://gideonchrapko.com';
const canonicalUrl = new URL(Astro.url.pathname, site).href;
const ogDescription = description ?? 'Front end developer — design and code.';
const ogImage = image ? (image.startsWith('http') ? image : new URL(image, site).href) : new URL('/og.png', site).href;
---

<!doctype html>
<html lang="en" class="m-0 w-full min-h-screen bg-[#EFFFC1] [scrollbar-gutter:stable]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={ogDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="m-0 flex min-h-screen w-full flex-col font-mono bg-[#EFFFC1]">
    <Header />
    <div class="min-h-0 flex-1 pt-16 pb-10">
      <div class="mx-auto max-w-7xl px-4">
        <main>
          <slot />
        </main>
      </div>
    </div>
    <Footer />
    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>
    <script is:inline>
      document.addEventListener('click', function (e) {
        var trigger = e.target && e.target.closest && e.target.closest('[data-popover-trigger]');
        if (trigger) {
          var root = trigger.closest('[data-popover]');
          var panel = root && root.querySelector('[data-popover-panel]');
          if (panel) {
            e.preventDefault();
            e.stopPropagation();
            var isOpen = panel.getAttribute('data-open') === 'true';
            panel.setAttribute('data-open', isOpen ? 'false' : 'true');
            panel.style.setProperty('display', isOpen ? 'none' : 'block', 'important');
            panel.style.setProperty('visibility', isOpen ? 'hidden' : 'visible', 'important');
            panel.style.setProperty('opacity', isOpen ? '0' : '1', 'important');
            panel.style.pointerEvents = isOpen ? 'none' : 'auto';
          }
          return;
        }
        document.querySelectorAll('[data-popover-panel][data-open="true"]').forEach(function (el) {
          el.setAttribute('data-open', 'false');
          el.style.setProperty('display', 'none', 'important');
          el.style.pointerEvents = 'none';
        });
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
          document.querySelectorAll('[data-popover-panel][data-open="true"]').forEach(function (el) {
            el.setAttribute('data-open', 'false');
            el.style.setProperty('display', 'none', 'important');
            el.style.pointerEvents = 'none';
          });
        }
      });
    </script>
  </body>
</html>
