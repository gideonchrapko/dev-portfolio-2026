---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	/** Page title (e.g. "About", "Projects"). Defaults to site name. */
	title?: string;
}
const { title } = Astro.props;
const pageTitle = title ? `${title} | Gideon Chrapko` : 'Gideon Chrapko | Front End Developer';
---
<!doctype html>
<html lang="en" class="m-0 w-full min-h-screen bg-[#EFFFC1]">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body class="m-0 flex min-h-screen w-full flex-col font-mono bg-[#EFFFC1]">
		<Header />
		<div class="min-h-0 flex-1 pt-16 pb-10">
			<div class="mx-auto max-w-7xl px-4">
				<main>
					<slot />
				</main>
			</div>
		</div>
		<Footer />
	</body>
</html>
