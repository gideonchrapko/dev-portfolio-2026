---
import Layout from '../layouts/Layout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'about');
if (!entry) throw new Error('Missing content: pages/about.md');

const { Content } = await render(entry);
---

<Layout title={entry.data.title}>
	<div class="mx-auto max-w-3xl px-4 py-8 font-mono">
		<span id="intro" class="block scroll-mt-24" aria-hidden="true"></span>
		<h1 class="text-2xl font-semibold text-gray-900">{entry.data.title}</h1>
		{entry.data.description && (
			<p class="mt-1 text-gray-600">{entry.data.description}</p>
		)}
		<div class="mt-6 space-y-4 [&_a]:text-blue-600 [&_a]:underline [&_h2]:mt-6 [&_h2]:text-xl [&_ul]:list-disc [&_ul]:pl-6">
			<Content />
		</div>
		<section id="experience" class="scroll-mt-24">
			<h2 class="mt-12 text-xl font-semibold text-gray-900">Experience</h2>
			<p class="mt-2 text-gray-600">This section can hold experience details or link to the main experience on the home page.</p>
		</section>
	</div>
</Layout>
