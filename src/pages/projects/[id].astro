---
import Layout from '../../layouts/Layout.astro';
import CategoryBadge from '../../components/CategoryBadge.astro';
import { getCollection, render } from 'astro:content';
import type { CategorySlug } from '../../data/categories';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((p) => ({ params: { id: p.id }, props: { entry: p } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, date, category, roles, tools, overview, sections, images, videos } = entry.data;
const categorySlug = (category ?? 'graphic-design') as CategorySlug;
---

<Layout title={title}>
	<article class="mx-auto max-w-3xl px-4 py-8 font-mono">
		<header>
			<h1 class="text-2xl font-semibold text-gray-900">{title}</h1>
			<div class="mt-1 flex flex-wrap items-center gap-2">
				{date && <span class="text-sm text-gray-500">{date.toLocaleDateString()}</span>}
				<CategoryBadge category={categorySlug} static />
			</div>
			{description && <p class="mt-1 text-gray-600">{description}</p>}
		</header>

		<!-- 1.1 Introduction: Role, Tools, Overview -->
		{(roles?.length || tools?.length || overview) && (
			<div class="mt-6 space-y-3 text-sm">
				{roles?.length && (
					<p>
						<span class="font-medium text-gray-500">ROLE</span>
						<br />
						<span class="text-gray-900">{roles.join(' · ')}</span>
					</p>
				)}
				{tools?.length && (
					<p>
						<span class="font-medium text-gray-500">TOOLS</span>
						<br />
						<span class="text-gray-900">{tools.join(' · ')}</span>
					</p>
				)}
				{overview && (
					<div>
						<p class="font-medium text-gray-500">PROJECT OVERVIEW</p>
						<p class="mt-1 whitespace-pre-line text-gray-900">{overview}</p>
					</div>
				)}
			</div>
		)}

		<!-- Sections (2.1, 2.2, …) with media -->
		{sections?.length ? (
			<div class="mt-10 space-y-10">
				{sections.map((section) => (
					<section>
						<h2 class="text-lg font-semibold text-gray-900">
							{section.id && `${section.id} - `}{section.title}
						</h2>
						{section.link && (
							<p class="mt-2">
								<a href={section.link} target="_blank" rel="noopener noreferrer" class="text-blue-600 underline">
									View link →
								</a>
							</p>
						)}
						{section.images?.length ? (
							<div class="mt-3 flex flex-wrap gap-2">
								{section.images.map((src) => (
									<img src={src} alt="" class="max-h-64 rounded object-cover" loading="lazy" />
								))}
							</div>
						) : null}
						{section.videos?.length ? (
							<div class="mt-3 space-y-2">
								{section.videos.map((src) => (
									<video src={src} controls class="w-full rounded" />
								))}
							</div>
						) : null}
					</section>
				))}
			</div>
		) : (images?.length || videos?.length) ? (
			<div class="mt-10">
				{images?.length ? (
					<div class="flex flex-wrap gap-2">
						{images.map((src) => (
							<img src={src} alt="" class="max-h-64 rounded object-cover" loading="lazy" />
						))}
					</div>
				) : null}
				{videos?.length ? (
					<div class="mt-4 space-y-2">
						{videos.map((src) => (
							<video src={src} controls class="w-full rounded" />
						))}
					</div>
				) : null}
			</div>
		) : null}

		<!-- Optional markdown body -->
		<div class="mt-8 space-y-4 [&_a]:text-blue-600 [&_a]:underline [&_h2]:mt-6 [&_h2]:text-xl [&_ul]:list-disc [&_ul]:pl-6">
			<Content />
		</div>
	</article>
</Layout>
