---
import Layout from '../../layouts/Layout.astro';
import CategoryBadge from '../../components/CategoryBadge.astro';
import { getCollection, render } from 'astro:content';
import type { CategorySlug } from '../../data/categories';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((p) => ({ params: { id: p.id }, props: { entry: p } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, date, category, roles, tools, overview, sections, images, videos, url } = entry.data;
const categorySlug = (category ?? 'graphic-design') as CategorySlug;
---

<Layout title={title}>
	<article class="px-4 py-8 font-mono">
		<header>
			<h1 class="text-2xl font-semibold text-gray-900">{title}</h1>
			<div class="mt-1 flex flex-wrap items-center gap-2">
				{date && <span class="text-sm text-gray-500">{date.toLocaleDateString()}</span>}
				<CategoryBadge category={categorySlug} static />
			</div>
			{url && (
				<p class="mt-3">
					<a
						href={url}
						target="_blank"
						rel="noopener noreferrer"
						class="group inline-flex items-center gap-2 rounded px-0.5 text-xl font-semibold text-gray-900 no-underline transition-colors hover:bg-gray-300/40"
					>
						<span class="underline decoration-gray-400 hover:decoration-gray-600">View site</span>
						<span class="inline-block text-xl no-underline transition-transform duration-200 -rotate-45 group-hover:rotate-0" aria-hidden="true">→</span>
					</a>
				</p>
			)}
			{description && <p class="mt-1 text-gray-600">{description}</p>}
		</header>

		<!-- 1.1 Introduction: Role, Tools, Overview -->
		{(roles?.length || tools?.length || overview) && (
			<div class="mt-6 space-y-3 text-sm">
				{roles?.length && (
					<p>
						<span class="font-medium text-gray-500">ROLE</span>
						<br />
						<span class="text-gray-900">{roles.join(' · ')}</span>
					</p>
				)}
				{tools?.length && (
					<p>
						<span class="font-medium text-gray-500">TOOLS</span>
						<br />
						<span class="text-gray-900">{tools.join(' · ')}</span>
					</p>
				)}
				{overview && (
					<div>
						<p class="font-medium text-gray-500">PROJECT OVERVIEW</p>
						<p class="mt-1 whitespace-pre-line text-gray-900">{overview}</p>
					</div>
				)}
			</div>
		)}

		{videos?.length ? (
			<div class="mt-10 w-full space-y-4">
				{videos.map((video) => (
					typeof video === 'string' ? (
						<video src={video} class="w-full rounded" autoplay muted loop playsinline />
					) : (
						<video class="w-full rounded" autoplay muted loop playsinline>
							{video.webm && <source type="video/webm" src={video.webm} />}
							{video.mp4 && <source type="video/mp4" src={video.mp4} />}
						</video>
					)
				))}
			</div>
		) : null}

		<!-- Sections (2.1, 2.2, …) with media -->
		{sections?.length ? (
			<div class="mt-10 space-y-16">
				{sections.map((section) => (
					<section>
						<h2 class="text-lg font-semibold text-gray-900">
							{section.id && `${section.id} - `}{section.title}
						</h2>
						{section.link && (
							<p class="mt-2">
								<a href={section.link} target="_blank" rel="noopener noreferrer" class="text-blue-600 underline">
									View link →
								</a>
							</p>
						)}
						{section.images?.length ? (
							<div class="project-gallery mt-12">
								{section.images.map((src) => (
									<div class="project-gallery__item">
										<img src={src} alt="" class="w-full rounded object-contain" loading="lazy" />
									</div>
								))}
							</div>
						) : null}
						{section.videos?.length ? (
							<div class="mt-3 space-y-2">
								{section.videos.map((video) => (
									typeof video === 'string' ? (
										<video src={video} class="w-full rounded" loop playsinline />
									) : (
										<video class="w-full rounded" loop playsinline>
											{video.webm && <source type="video/webm" src={video.webm} />}
											{video.mp4 && <source type="video/mp4" src={video.mp4} />}
										</video>
									)
								))}
							</div>
						) : null}
					</section>
				))}
			</div>
		) : images?.length ? (
			<div class="mt-10">
				<div class="project-hero-gallery space-y-20">
						{images.slice(0, 2).map((src) => (
							<div class="project-hero-gallery__full">
								<img src={src} alt="" class="w-full rounded object-contain" loading="lazy" />
							</div>
						))}
						{images.length >= 4 && (
							<div class="project-hero-gallery__pair">
								<div class="project-hero-gallery__third">
									<img src={images[2]} alt="" class="w-full max-w-[400px] rounded object-contain" loading="lazy" />
								</div>
								<div class="project-hero-gallery__fourth">
									<img src={images[3]} alt="" class="w-full rounded object-contain" loading="lazy" />
								</div>
							</div>
						)}
						{images.length === 3 && (
							<div class="project-hero-gallery__full">
								<img src={images[2]} alt="" class="w-full rounded object-contain" loading="lazy" />
							</div>
						)}
						{images.length > 4 && (
							<div class="project-gallery mt-16">
								{images.slice(4).map((src) => (
									<div class="project-gallery__item">
										<img src={src} alt="" class="w-full rounded object-contain" loading="lazy" />
									</div>
								))}
							</div>
						)}
				</div>
			</div>
		) : null}

		<!-- Optional markdown body -->
		<div class="mt-8 space-y-4 [&_a]:text-blue-600 [&_a]:underline [&_h2]:mt-6 [&_h2]:text-xl [&_ul]:list-disc [&_ul]:pl-6">
			<Content />
		</div>
	</article>
</Layout>

<style>
	/* First two: full width. Third + fourth: side by side, third max 400px, staggered */
	.project-hero-gallery__full img {
		display: block;
	}
	.project-hero-gallery__pair {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-start;
		gap: 3rem;
	}
	.project-hero-gallery__third {
		flex: 0 0 auto;
		max-width: 400px;
	}
	.project-hero-gallery__third img {
		display: block;
	}
	.project-hero-gallery__fourth {
		flex: 1 1 300px;
		margin-top: 4rem;
	}
	.project-hero-gallery__fourth img {
		display: block;
		max-width: 100%;
	}
	@media (max-width: 640px) {
		.project-hero-gallery__fourth {
			margin-top: 2rem;
		}
	}
	/* Remaining images (5+): 2-column gallery */
	.project-gallery {
		column-count: 2;
		column-gap: 3rem;
	}
	.project-gallery__item {
		break-inside: avoid;
		margin-bottom: 3rem;
	}
	.project-gallery__item img {
		display: block;
		vertical-align: top;
	}
	@media (max-width: 640px) {
		.project-gallery {
			column-count: 1;
		}
	}
</style>
